---
import { getCollection } from 'astro:content';
const posts = await getCollection('posts');
---
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<title>Yo Soy Historia | Archivo</title>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	</head>
	<body class="bg-zinc-950 text-zinc-300 font-serif antialiased selection:bg-red-900 selection:text-white">
		<div class="max-w-3xl mx-auto px-6 py-12 border-x border-zinc-900 min-h-screen shadow-2xl shadow-black">
			<header class="text-center border-b-4 border-double border-zinc-800 pb-8 mb-12">
				<h1 class="text-5xl md:text-6xl uppercase tracking-tighter text-zinc-100 font-bold">Yo Soy Historia</h1>
				<p class="text-red-700 font-mono uppercase tracking-widest text-xs mt-4 font-bold">Investigaciones, misterios y casos</p>
			</header>
			<main>
				{posts && posts.length === 0 ? (
					<p class="text-center text-zinc-600 font-mono text-sm">ARCHIVOS NO ENCONTRADOS.</p>
				) : (
					posts && posts.map(post => (
						<article class="mb-16 border-b border-zinc-900 pb-8 group">
							<a href={`/posts/${post.slug}`} class="block text-decoration-none">
								<h2 class="text-3xl font-bold text-zinc-100 mb-2 group-hover:text-red-500 transition-colors duration-300">{post.data.title}</h2>
							</a>
							<div class="font-mono text-xs text-zinc-500 mb-4 border-l-2 border-red-900 pl-2">
								Fecha de publicación: {post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('es-ES') : 'DESCONOCIDA'}
							</div>
							<p class="text-lg text-zinc-400 leading-relaxed mb-4">{post.data.description}</p>
							<a href={`/posts/${post.slug}`} class="inline-block font-mono text-sm text-zinc-100 border-b border-zinc-700 hover:border-red-500 hover:text-red-500 transition-all pb-1">¿Cómo pasó todo esto?</a>
						</article>
					))
				)}
			</main>
		</div>
	</body>
</html>
