---
import { getCollection } from 'astro:content';
const posts = await getCollection('posts');
---
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<title>Yo Soy Historia | Archivo</title>
		<link href="https://fonts.googleapis.com/css2?family=PT+Serif:wght@400;700&display=swap" rel="stylesheet">
	</head>
	<body style="background-color: #050505; color: #e5e5e5; font-family: 'PT Serif', serif; margin: 0;">
		<div style="max-width: 800px; margin: 0 auto; padding: 4rem 2rem; border-left: 1px solid #222; border-right: 1px solid #222; min-height: 100vh;">
			<header style="text-align: center; border-bottom: 4px double #333; padding-bottom: 2rem; margin-bottom: 3rem;">
				<h1 style="font-size: 4rem; text-transform: uppercase; margin: 0; letter-spacing: -2px;">Yo Soy Historia</h1>
				<p style="color: #666; text-transform: uppercase; letter-spacing: 4px; font-size: 0.8rem; margin-top: 1rem;">Investigaciones, misterios y casos</p>
			</header>
			<main>
				{posts && posts.length === 0 ? (
					<p style="text-align: center; color: #444;">No hay expedientes cargados todavía.</p>
				) : (
					posts && posts.map(post => (
						<article style="margin-bottom: 4rem; border-bottom: 1px solid #111; padding-bottom: 2rem;">
							<h2 style="font-size: 2.5rem; margin-bottom: 0.5rem;">{post.data.title}</h2>
							<p style="color: #555; font-style: italic;">Publicado el {post.data.pubDate ? post.data.pubDate.toLocaleDateString() : 'Recientemente'}</p>
							<p style="font-size: 1.2rem; color: #aaa; line-height: 1.6;">{post.data.description}</p>
							<a href={`/posts/${post.slug}`} style="color: white; font-weight: bold; text-decoration: none; border-bottom: 1px solid white;">Leer más →</a>
						</article>
					))
				)}
			</main>
		</div>
	</body>
</html>
